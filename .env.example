# Copy this file to .env and fill in the values.
# DO NOT commit .env to Git — it's already in .gitignore.

# ── Site analytics & AdSense (Vercel Production/Preview) ─────────────
# PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxx
# PUBLIC_GOOGLE_SITE_VERIFICATION=   # optional meta tag; or use public/google*.html
# See docs/ADSENSE_AND_GSC_CHECKLIST.md

# ── X (Twitter) API Credentials ──────────────────────────────────────
# Get from: https://developer.x.com/en/portal/dashboard
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ── Admin CMS — Turso DB ──────────────────────────────────────────────
# turso db show gsf-blog-cms → URL 확인
# turso db tokens create gsf-blog-cms → 토큰 발급
TURSO_DATABASE_URL=libsql://gsf-blog-cms-asiaunion.aws-ap-northeast-1.turso.io
TURSO_AUTH_TOKEN=

# ── Admin CMS — Google OAuth (Arctic) ────────────────────────────────
# https://console.cloud.google.com → OAuth 2.0 클라이언트 생성
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://gsfark.com/admin/api/auth/callback

# ── Admin CMS — 접근 제어 ─────────────────────────────────────────────
# 쉼표로 구분된 허용 이메일 목록
ADMIN_EMAILS=me@gmail.com,wife@gmail.com

# ── Admin CMS — JWT ───────────────────────────────────────────────────
# openssl rand -base64 32 로 생성
JWT_SECRET=
JWT_SECRET_PREVIOUS=

# ── Admin CMS — GitHub (발행용) ───────────────────────────────────────
# Fine-grained token: contents:write 권한만
GITHUB_TOKEN=

# ── Admin CMS — AG 연동 ───────────────────────────────────────────────
AG_API_KEY=

# ── Notion CMS 파이프라인 ──────────────────────────────────────────────
# Settings → My connections → Create new integration → Token 복사
NOTION_TOKEN=
# Notion DB URL → 말미 32자리 ID (대시 없이)
NOTION_DATABASE_ID=

# ── Vercel — Preview URL 취득용 ───────────────────────────────────────
# https://vercel.com/account/tokens → Full Account 범위
VERCEL_TOKEN=

# ── CF Worker — GitHub dispatch용 ────────────────────────────────────
# Fine-grained PAT: actions:write 권한
# CF Worker Secret으로 등록: wrangler secret put CF_WORKER_GITHUB_TOKEN
# (여기선 로컬 테스트용으로만 사용)
CF_WORKER_GITHUB_TOKEN=

# ── LLM (Voice Rewrite / 번역용) — GitHub Actions ────────────────────
# GitHub Actions secret에도 동일하게 등록 필요
GEMINI_API_KEY=
