---
/**
 * GDPR Cookie Consent Banner
 * Minimal, non-intrusive banner that appears at the bottom of the screen.
 * Persists consent in localStorage so it only shows once.
 */
import type { UiLang } from "@/i18n/ui";

type Props = {
  lang?: UiLang;
};

const { lang = "en" } = Astro.props;

const labels: Record<string, { message: string; accept: string; decline: string; learnMore: string }> = {
  en: {
    message: "This site uses cookies for functionality and advertising (Google AdSense). By continuing, you consent to their use.",
    accept: "Accept",
    decline: "Decline",
    learnMore: "Privacy Policy",
  },
  ko: {
    message: "이 사이트는 기능 개선과 광고(Google AdSense)를 위해 쿠키를 사용합니다. 계속 이용하시면 쿠키 사용에 동의하는 것으로 간주됩니다.",
    accept: "동의",
    decline: "거부",
    learnMore: "개인정보처리방침",
  },
  ja: {
    message: "当サイトでは、機能向上と広告配信（Google AdSense）のためにCookieを使用しています。引き続きご利用いただくことで、Cookieの使用に同意したものとみなされます。",
    accept: "同意する",
    decline: "拒否する",
    learnMore: "プライバシーポリシー",
  },
};

const t = labels[lang] ?? labels.en;
const privacyHref = lang === "en" ? "/privacy-policy/" : `/${lang}/privacy-policy/`;
---

<div
  id="cookie-consent-banner"
  class="cookie-banner"
  role="dialog"
  aria-label="Cookie consent"
  style="display:none;"
>
  <div class="cookie-inner">
    <p class="cookie-text">
      {t.message}
      <a href={privacyHref} class="cookie-link">{t.learnMore}</a>
    </p>
    <div class="cookie-actions">
      <button id="cookie-decline" class="cookie-btn cookie-btn--decline">{t.decline}</button>
      <button id="cookie-accept" class="cookie-btn cookie-btn--accept">{t.accept}</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: rgba(17, 17, 17, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(52, 211, 153, 0.2);
    padding: 1rem 1.5rem;
    animation: slideUp 0.4s ease-out;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .cookie-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cookie-text {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.85rem;
    line-height: 1.5;
    flex: 1;
    min-width: 280px;
    margin: 0;
  }

  .cookie-link {
    color: #34d399;
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-left: 0.25rem;
  }

  .cookie-link:hover {
    color: #6ee7b7;
  }

  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .cookie-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all 0.2s ease;
  }

  .cookie-btn--accept {
    background: #34d399;
    color: #111;
  }
  .cookie-btn--accept:hover {
    background: #6ee7b7;
    transform: translateY(-1px);
  }

  .cookie-btn--decline {
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .cookie-btn--decline:hover {
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.4);
  }

  @media (max-width: 640px) {
    .cookie-inner {
      flex-direction: column;
      text-align: center;
    }
    .cookie-actions {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script is:inline>
  (function () {
    var consent = localStorage.getItem("gsf_cookie_consent");
    if (consent) return; // already answered
    var banner = document.getElementById("cookie-consent-banner");
    if (banner) banner.style.display = "block";

    document.getElementById("cookie-accept")?.addEventListener("click", function () {
      localStorage.setItem("gsf_cookie_consent", "accepted");
      if (banner) banner.style.display = "none";
      if (typeof window.__gsfEnableAdsense === "function") window.__gsfEnableAdsense();
    });
    document.getElementById("cookie-decline")?.addEventListener("click", function () {
      localStorage.setItem("gsf_cookie_consent", "declined");
      if (banner) banner.style.display = "none";
    });
  })();
</script>
