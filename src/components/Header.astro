---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import LangBanner from "./LangBanner.astro";
import { SITE } from "@/config";
import { getUi, type UiLang } from "@/i18n/ui";

type Props = { uiLang?: UiLang };

const { uiLang: uiLangProp } = Astro.props as Props;
const { pathname } = Astro.url;
const { locale } = Astro.params;
const lang = (
  uiLangProp ??
  (locale === "ko" || locale === "ja" ? locale : "en")
) as UiLang;
const l = lang === "en" ? "" : `/${lang}`;
const L = getUi(lang);

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const normalizePath = (p: string) => {
  if (p === "/") return p;
  return p.endsWith("/") ? p.slice(0, -1) : p;
};

/** Exact match or current URL is a subpath of this nav target (locale-safe). */
const isActive = (path: string) => {
  const cur = normalizePath(currentPath);
  const target = normalizePath(path);
  if (cur === target) return true;
  if (target !== "/" && cur.startsWith(`${target}/`)) return true;
  return false;
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  {L.skipToContent}
</a>

<LangBanner uiLang={lang} pathname={pathname} locale={locale} />
<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-0.5 sm:py-1",
      "border-b border-border",
      "relative w-full bg-background",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href={l || "/"}
      class="py-1 flex items-center whitespace-nowrap sm:my-auto transition-transform duration-300 hover:scale-[1.02] active:scale-95"
      aria-label={SITE.title}
    >
      <div class="flex items-baseline gap-[1px]">
        <span class="text-2xl sm:text-3xl font-extrabold tracking-tighter text-accent" style="font-family: 'Playfair Display', 'Didot', 'Bodoni MT', 'Times New Roman', serif;">
          Tokyo
        </span>
        <span class="text-2xl sm:text-3xl font-bold tracking-tight text-foreground" style="font-family: 'Playfair Display', 'Didot', 'Bodoni MT', 'Times New Roman', serif;">
          Korean
        </span>
      </div>
    </a>
    <nav
      id="nav-menu"
      class="flex flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline self-end p-2 sm:hidden"
        aria-label={L.openMenu}
        aria-expanded="false"
        aria-controls="menu-items"
        data-open-label={L.openMenu}
        data-close-label={L.closeMenu}
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "mt-4 grid w-44 grid-cols-2 place-content-center gap-2",
          "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
          "sm:[&>li>a]:whitespace-nowrap",
          "[&>li]:max-sm:min-w-0 sm:[&>li]:shrink-0",
          "hidden",
          "sm:mt-0 sm:flex sm:w-auto sm:flex-nowrap sm:gap-x-5 sm:gap-y-0 sm:justify-end items-center",
        ]}
      >
        <li class="col-span-2">
          <a
            href={`${l}/posts/`}
            class:list={[
              "transition-colors hover:text-accent",
              { "active-nav": isActive(`${l}/posts`) },
            ]}
          >
            {L.navPosts}
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={`${l}/tags/`}
            class:list={[
              "transition-colors hover:text-accent",
              { "active-nav": isActive(`${l}/tags`) },
            ]}
          >
            {L.navTags}
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={`${l}/topics/`}
            class:list={[
              "transition-colors hover:text-accent",
              { "active-nav": isActive(`${l}/topics`) },
            ]}
          >
            {L.navTopics}
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={`${l}/contact/`}
            class:list={[
              "transition-colors hover:text-accent",
              { "active-nav": isActive(`${l}/contact`) },
            ]}
          >
            {L.navContact}
          </a>
        </li>
        <li class="col-span-2">
          <a
            href={`${l}/about/`}
            class:list={[
              "transition-colors hover:text-accent",
              { "active-nav": isActive(`${l}/about`) },
            ]}
          >
            {L.navAbout}
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-2">
              <LinkButton
                href="/archives/"
                class:list={[
                  "focus-outline flex justify-center p-3 sm:p-1 transition-colors hover:text-accent",
                  {
                    "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                  },
                ]}
                title={L.navArchives}
                aria-label={L.navArchives}
              >
                <IconArchive class="hidden sm:inline-block" />
                <span class="sm:sr-only">{L.navArchives}</span>
              </LinkButton>
            </li>
          )
        }
        <li class="col-span-1 flex items-center justify-center">
          <LinkButton
            href={`${l}/search/`}
            class:list={[
              "focus-outline flex p-3 sm:p-1 transition-colors hover:text-accent",
              { "[&>svg]:stroke-accent": isActive(`${l}/search`) },
            ]}
            title={L.navSearch}
            aria-label={L.navSearch}
          >
            <IconSearch />
            <span class="sr-only">{L.navSearch}</span>
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="col-span-1 flex items-center justify-center">
              <button
                id="theme-btn"
                class="focus-outline relative size-12 rounded-sm p-4 transition-colors sm:size-8 hover:[&>svg]:stroke-accent"
                title={L.themeToggleTitle}
                aria-label={L.themeToggleAria}
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (
      !(menuBtn instanceof HTMLElement) ||
      !menuItems ||
      !menuIcon ||
      !closeIcon
    )
      return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute(
        "aria-label",
        openMenu
          ? (menuBtn.dataset.openLabel ?? "Open menu")
          : (menuBtn.dataset.closeLabel ?? "Close menu")
      );

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
