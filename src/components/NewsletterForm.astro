---
/**
 * NewsletterForm.astro
 * Buttondown newsletter subscription form.
 * Uses fetch() to post to Buttondown's embed API and shows an inline
 * success/error message — no popup window, works on mobile and with
 * popup-blockers.
 *
 * Props:
 *   variant     – "inline" (hero / footer) or "card" (post bottom)
 *   lang        – UiLang for i18n labels
 *   customCta   – override the default CTA button label
 *   downloadUrl – if set, triggers a file download on submit
 */
import { getUi, type UiLang } from "@/i18n/ui";

type Props = {
  variant?: "inline" | "card";
  customCta?: string;
  downloadUrl?: string;
  class?: string;
};

const { variant = "card", customCta, downloadUrl, class: className } = Astro.props;
const L = getUi("ko");
const finalCta = customCta || L.newsletterCta;

// i18n success / error messages
const i18nSuccess: Record<string, string> = {
  ko: "✅ 확인 이메일을 보내드렸습니다! 받은편지함을 확인해 주세요.",
  ja: "✅ 確認メールをお送りしました！受信トレイをご確認ください。",
  en: "✅ Check your inbox to confirm your subscription!",
};
const i18nError: Record<string, string> = {
  ko: "⚠️ 오류가 발생했습니다. 잠시 후 다시 시도해 주세요.",
  ja: "⚠️ エラーが発生しました。しばらくしてから再度お試しください。",
  en: "⚠️ Something went wrong. Please try again later.",
};
const i18nDuplicate: Record<string, string> = {
  ko: "이미 구독 중인 이메일입니다.",
  ja: "すでに購読済みのメールアドレスです。",
  en: "You're already subscribed!",
};

const BUTTONDOWN_USERNAME = "gsf";
const formEndpoint = `https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`;
---

{
  variant === "card" ? (
    <section
      id="newsletter-subscribe"
      class="mt-6 rounded-xl border border-accent/30 bg-gradient-to-br from-accent/5 to-transparent p-5"
    >
      <h2 class="text-lg font-semibold">{L.newsletterTitle}</h2>
      <p class="mt-2 text-sm leading-relaxed text-foreground/75">
        {L.newsletterBody}
      </p>
      <form
        class="bd-form mt-4 flex flex-col gap-3 sm:flex-row sm:items-end"
        data-endpoint={formEndpoint}
        data-download={downloadUrl}
        data-lang="ko"
        data-variant="card"
      >
        <div class="flex-1">
          <label for="bd-email-card" class="sr-only">
            {L.newsletterEmailLabel}
          </label>
          <input
            type="email"
            name="email"
            id="bd-email-card"
            required
            placeholder={L.newsletterPlaceholder}
            class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-foreground/40 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
          />
        </div>
        <button
          type="submit"
          class="bd-btn rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-white transition-all hover:opacity-90 hover:shadow-md active:scale-[0.98]"
        >
          {finalCta}
        </button>
      </form>
      <p class="bd-msg mt-3 hidden text-sm font-medium" aria-live="polite"></p>
      <p class="mt-3 text-xs text-foreground/50">{L.newsletterDisclaimer}</p>
    </section>
  ) : (
    /* inline variant for hero / footer */
    <div class={`bd-inline-wrapper mt-2 flex w-full flex-col gap-3${className ? ` ${className}` : ""}`}>
      <form
        class="bd-form flex w-full flex-col gap-3 sm:flex-row"
        data-endpoint={formEndpoint}
        data-download={downloadUrl}
        data-lang="ko"
        data-variant="inline"
        id="newsletter-inline"
      >
        <label for="bd-email-inline" class="sr-only">
          {L.newsletterEmailLabel}
        </label>
        <input
          type="email"
          name="email"
          id="bd-email-inline"
          required
          placeholder={L.newsletterPlaceholder}
          class="flex-1 rounded-full border border-border bg-background/80 px-5 py-3 text-sm text-foreground placeholder:text-foreground/40 backdrop-blur-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
        />
        <button
          type="submit"
          class="bd-btn shrink-0 w-auto whitespace-nowrap rounded-full bg-accent px-4 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:scale-105 hover:shadow-xl active:scale-[0.98]"
        >
          {finalCta}
        </button>
      </form>
      <p class="bd-msg hidden text-sm font-medium" aria-live="polite"></p>
    </div>
  )
}

<script>
  const SUCCESS: Record<string, string> = {
    ko: "✅ 확인 이메일을 보내드렸습니다! 받은편지함을 확인해 주세요.",
    ja: "✅ 確認メールをお送りしました！受信トレイをご確認ください。",
    en: "✅ Check your inbox to confirm your subscription!",
  };
  const ERROR: Record<string, string> = {
    ko: "⚠️ 오류가 발생했습니다. 잠시 후 다시 시도해 주세요.",
    ja: "⚠️ エラーが発生しました。しばらくしてから再度お試しください。",
    en: "⚠️ Something went wrong. Please try again later.",
  };
  const DUPLICATE: Record<string, string> = {
    ko: "이미 구독 중인 이메일입니다. 😊",
    ja: "すでに購読済みのメールアドレスです。😊",
    en: "You're already subscribed! 😊",
  };

  document.querySelectorAll<HTMLFormElement>("form.bd-form").forEach(form => {
    const endpoint = form.dataset.endpoint!;
    const lang = form.dataset.lang ?? "en";
    const variant = form.dataset.variant ?? "card";
    const btn = form.querySelector<HTMLButtonElement>("button.bd-btn");

    // For card variant, msg lives outside the form; for inline, it's a sibling
    const msg =
      variant === "card"
        ? form.closest("section")?.querySelector<HTMLParagraphElement>(".bd-msg")
        : form.closest(".bd-inline-wrapper")?.querySelector<HTMLParagraphElement>(".bd-msg");

    function showMsg(text: string, isError = false) {
      if (!msg) return;
      msg.textContent = text;
      msg.classList.remove("hidden", "text-foreground/70", "text-red-500");
      msg.classList.add(isError ? "text-red-500" : "text-foreground/70");
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const emailInput = form.querySelector<HTMLInputElement>("input[type='email']");
      const email = emailInput?.value.trim() ?? "";
      if (!email) return;

      // Trigger optional file download
      const downloadUrl = form.dataset.download;
      if (downloadUrl) {
        const a = document.createElement("a");
        a.href = downloadUrl;
        a.download = "";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      }

      if (btn) { btn.disabled = true; btn.textContent = "..."; }

      try {
        const body = new URLSearchParams({ email });
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: body.toString(),
        });

        if (res.ok || res.status === 201) {
          form.classList.add("hidden");
          showMsg(SUCCESS[lang] ?? SUCCESS.en);
        } else if (res.status === 400) {
          // Already subscribed or validation error — try to parse
          const data = await res.json().catch(() => ({}));
          const detail: string = data?.detail ?? "";
          if (detail.toLowerCase().includes("already") || detail.includes("중복")) {
            showMsg(DUPLICATE[lang] ?? DUPLICATE.en);
          } else {
            showMsg(ERROR[lang] ?? ERROR.en, true);
          }
          if (btn) { btn.disabled = false; btn.textContent = btn.dataset.label ?? "Subscribe"; }
        } else {
          showMsg(ERROR[lang] ?? ERROR.en, true);
          if (btn) { btn.disabled = false; }
        }
      } catch {
        showMsg(ERROR[lang] ?? ERROR.en, true);
        if (btn) { btn.disabled = false; }
      }
    });

    // Store original label for reset
    if (btn) btn.dataset.label = btn.textContent ?? "Subscribe";
  });
</script>
