---
import type { UiLang } from "@/i18n/ui";

type Props = {
  lang?: UiLang;
};

const { lang = "en" } = Astro.props;

const copy: Record<UiLang, string> = {
  en: "This article may contain affiliate links. If you use them, GSF may earn a commission at no extra cost to you. This does not affect our editorial standards or source citations.",
  ko: "이 글에는 제휴(어필리에이트) 링크가 포함될 수 있습니다. 링크를 통해 이용하실 경우 GSF에 수수료가 지급될 수 있으나, 독자 부담은 없으며 편집·출처 기준에는 영향을 주지 않습니다.",
  ja: "本記事にはアフィリエイトリンクが含まれる場合があります。リンク経由の利用でGSFに報酬が発生することがありますが、読者の追加負担はなく、編集・出典方針には影響しません。",
};
---

<aside
  class="mt-6 rounded-lg border border-border/80 bg-muted/30 px-4 py-3 text-xs leading-relaxed text-foreground/70"
  data-affiliate-disclosure
>
  {copy[lang]}
</aside>
