---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { getUi, type UiLang } from "@/i18n/ui";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
  uiLang?: UiLang;
} & HTMLAttributes<"footer">;

const {
  noMarginTop = false,
  uiLang: uiLangProp,
  class: className,
  ...attrs
} = Astro.props;

const { locale } = Astro.params;
const lang = (
  uiLangProp ??
  (locale === "ko" || locale === "ja" ? locale : "en")
) as UiLang;
const l = lang === "en" ? "" : `/${lang}`;
const L = getUi(lang);
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div class="py-6 sm:py-8 border-t border-border flex flex-col gap-4 sm:gap-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center text-sm opacity-80 gap-3 sm:gap-4">
        <a href={`${l}/about/`} class="link-subtle">{L.footerAbout}</a>
        <span>&middot;</span>
        <a href={`${l}/contact/`} class="link-subtle">{L.footerContact}</a>
        <span>&middot;</span>
        <a href={`${l}/privacy-policy/`} class="link-subtle">{L.footerPrivacy}</a>
      </div>
      <Socials />
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-center sm:justify-start text-xs sm:text-sm opacity-60 text-center sm:text-left gap-1 sm:gap-2">
      <span>{L.footerCopyright} &#169; {currentYear} TokyoKorean.</span>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>{L.footerAllRights}</span>
    </div>
  </div>
</footer>
