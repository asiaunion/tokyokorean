---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { getUi, type UiLang } from "@/i18n/ui";
import { TOPIC_HUB_SLUGS, type TopicHubKey } from "@/data/topicHubs";

const posts = await getCollection("blog", ({ id }) => id.startsWith(`ko/`));
const L = getUi("ko");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const recentHomeLimit = Math.max(SITE.postPerIndex, 6);
const hubOrder: TopicHubKey[] = [
  "urbanInvestment",
  "macroPolicy",
  "tokyoLife",
  "essay",
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class="-mx-4 relative border-b border-border overflow-hidden"
    >

      <!-- 2-column hero grid -->
      <div class="grid grid-cols-1 lg:grid-cols-[10fr_10fr] lg:items-stretch">

        <!-- 좌: 타이틀 -->
        <div class="flex flex-col justify-center px-8 lg:pl-10 lg:pr-12 pt-10 pb-10 min-h-0 lg:min-h-[42vh] bg-background">
          <h1 class="mt-4 text-4xl font-extrabold sm:text-5xl lg:text-[2.75rem] tracking-tight leading-[1.6] [word-break:keep-all]">
            {L.heroTitleLine1}<br />{L.heroTitleLine2}{L.heroTitleLine3 ? <><br />{L.heroTitleLine3}</> : null}
          </h1>
          <p class="mt-auto pt-10 text-xs font-medium tracking-wide text-foreground/35 hidden lg:block">
            TokyoKorean · Nihonbashi, Tokyo
          </p>
        </div>

        <!-- 우: 서브카피 + CTA + 소셜 + 뉴스레터 -->
        <!-- DOM 순서: 서브카피 → CTA → 소셜 → 뉴스레터 -->
        <!-- 모바일: CTA가 order-first로 타이틀 직후 표시 -->
        <!-- 데스크탑: order-none으로 DOM 순서 그대로 (서브카피 다음) -->
        <div class="relative min-h-0 lg:min-h-[42vh] overflow-hidden lg:rounded-l-3xl self-stretch">

          <!-- 배경 레이어 -->
          <div class="absolute inset-0 bg-accent/8 dark:bg-accent/5 z-0"></div>

          <style is:inline>
            @keyframes blob {
              0% { transform: translate(0px, 0px) scale(1); }
              33% { transform: translate(30px, -50px) scale(1.1); }
              66% { transform: translate(-20px, 20px) scale(0.9); }
              100% { transform: translate(0px, 0px) scale(1); }
            }
            .animate-blob { animation: blob 15s infinite alternate ease-in-out; }
            .animation-delay-2000 { animation-delay: 2s; }
            .animation-delay-4000 { animation-delay: 4s; }
          </style>

          <!-- Aurora -->
          <div class="absolute inset-0 z-[1] pointer-events-none">
            <div class="absolute -top-[20%] -left-[10%] w-[60%] h-[60%] rounded-full bg-accent/20 blur-[100px] animate-blob mix-blend-normal dark:mix-blend-screen"></div>
            <div class="absolute top-[10%] -right-[10%] w-[50%] h-[70%] rounded-full bg-emerald-500/15 blur-[100px] animate-blob animation-delay-2000 mix-blend-normal dark:mix-blend-screen"></div>
            <div class="absolute -bottom-[20%] left-[20%] w-[60%] h-[60%] rounded-full bg-teal-500/20 blur-[120px] animate-blob animation-delay-4000 mix-blend-normal dark:mix-blend-screen"></div>
          </div>

          <!-- 콘텐츠 레이어 -->
          <div class="relative z-10 flex flex-col justify-center h-full px-8 pt-6 pb-6 gap-6">
            <div class="flex flex-col gap-6 my-auto">

              <!-- 구분선 + 서브카피 (DOM 1번째, 데스크탑 표시 순서 1번째) -->
              <div>
                <div class="w-8 h-[2px] bg-accent mb-4"></div>
                <p class="text-lg sm:text-xl font-medium text-foreground/90 leading-relaxed whitespace-pre-line">
                  {L.heroTagline}
                </p>
                <p class="mt-3 text-base text-foreground/65 leading-relaxed">
                  {L.heroDescription}
                </p>
              </div>

              <!-- CTA 버튼 (DOM 2번째)
                   모바일: order-first → 타이틀(좌 컬럼) 직후 표시
                   데스크탑: order-none → DOM 순서 그대로, 서브카피 다음 -->
              <div class="flex flex-nowrap gap-2 order-first lg:order-none">
                <a
                  href={`/posts/`}
                  class="whitespace-nowrap inline-block bg-foreground text-background px-4 py-2.5 rounded-full text-sm font-semibold shadow-lg hover:scale-105 hover:shadow-xl transition-all"
                  data-cta="start-reading"
                  data-cta-location="home-hero"
                >
                  {L.heroCtaRead}
                </a>
                <a
                  href={`/about/`}
                  class="whitespace-nowrap inline-block border-2 border-foreground text-foreground px-4 py-2.5 rounded-full text-sm font-semibold hover:bg-foreground hover:text-background transition-all"
                  data-cta="about-author"
                  data-cta-location="home-hero"
                >
                  {L.heroCtaAbout}
                </a>
              </div>

              <!-- 소셜 링크 (DOM 3번째) -->
              {
                SOCIALS.length > 0 && (
                  <div class="flex max-sm:flex-col sm:items-center mt-1">
                    <div class="me-3 mb-1 whitespace-nowrap sm:mb-0 text-sm font-medium text-foreground/70">{L.socialLinksLabel}</div>
                    <Socials trackingContext="home-hero" />
                  </div>
                )
              }

              <!-- 뉴스레터 제거됨 -->

            </div>
          </div>

        </div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">{L.sectionFeatured}</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">{L.sectionRecentPosts}</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < recentHomeLimit && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <section id="topic-cards" class="pt-4 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">{L.sectionExploreTopics}</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {
          hubOrder.map(key => (
            <a
              href={`/topics/#hub-${key}`}
              class="group rounded-xl border border-border bg-card p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-accent"
            >
              <h3 class="text-base font-semibold text-foreground">{L.topicHubs[key].title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-foreground/75">
                {L.topicHubs[key].description}
              </p>
              <p class="mt-3 text-xs text-foreground/60">
                {TOPIC_HUB_SLUGS[key].length} {L.topicHubPostsLabel}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <div class="my-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <LinkButton href={`/posts/`}>
        {L.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
      <LinkButton
        href={`/topics/`}
        class="rounded-full border border-border px-4 py-2 text-sm font-medium transition-all duration-300 hover:-translate-y-1 hover:shadow-sm hover:border-accent"
      >
        {L.topicsFromHome}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      // Find the current locale from the html tag to set the backUrl properly
      sessionStorage.setItem("backUrl", '/');
    }
  });
</script>
