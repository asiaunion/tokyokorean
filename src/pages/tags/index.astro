---
import { getCollection } from "astro:content";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
import Tag from "@/components/Tag.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import { SITE } from "@/config";
import { getUi, type UiLang } from "@/i18n/ui";

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
  ];
}

const { locale } = Astro.params;
const lang = locale || "en";
const L = getUi(lang as UiLang);
const posts = await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`));

let tags = getUniqueTags(posts);
---

<Layout title={`${L.pageTitleTags} | ${SITE.title}`} robotsMeta="noindex, follow">
  <Header />
  <Main pageTitle={L.pageTitleTags} pageDesc={L.pageDescTags}>
    <ul class="flex flex-wrap gap-6">
      {tags.map(({ tag, tagName }) => <Tag {tag} {tagName} />)}
    </ul>
  </Main>
  <Footer />
</Layout>
