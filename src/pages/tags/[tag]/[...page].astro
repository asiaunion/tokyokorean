---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";
import { getUi, type UiLang } from "@/i18n/ui";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const locales = ["en", "ko", "ja"];

  return locales.flatMap(locale => {
    const lang = locale;
    const langPosts = posts.filter(post => post.id.startsWith(`${lang}/`));
    const tags = getUniqueTags(langPosts);

    return tags.flatMap(({ tag, tagName }) => {
      const tagPosts = getPostsByTag(langPosts, tag);

      return paginate(tagPosts, {
        params: { locale: locale === "en" ? undefined : locale, tag },
        props: { tagName },
        pageSize: SITE.postPerPage,
      });
    });
  });
}

const { tag, locale } = Astro.params;
const { page, tagName } = Astro.props;
const L = getUi((locale || "en") as UiLang);
---

<Layout title={`${L.tagPageTitlePrefix} ${tagName} | ${SITE.title}`} robotsMeta="noindex, follow">
  <Header />
  <Main
    pageTitle={[L.tagPageTitlePrefix, `${tagName}`]}
    titleTransition={tag}
    pageDesc={L.tagPageDesc.replace("{tag}", tagName)}
  >
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
