---
import { ClientRouter } from "astro:transitions";
import {
  PUBLIC_GOOGLE_SITE_VERIFICATION,
  PUBLIC_ADSENSE_PUBLISHER_ID,
  PUBLIC_GA4_MEASUREMENT_ID,
} from "astro:env/client";
import { SITE, PUBLIC_PROFILES } from "@/config";
import "@/styles/global.css";

import type { UiLang } from "@/i18n/ui";

type Props = {
  /** When set (e.g. 404 /archives), overrides `Astro.params.locale` for `<html lang>`. */
  htmlLang?: UiLang;
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  /** Post tags → JSON-LD keywords */
  tags?: string[];
  /** Short plain-text excerpt for JSON-LD `articleBody` (e.g. frontmatter description) */
  articleBody?: string;
  /** When set, replaces default BlogPosting JSON-LD (e.g. About → Person). */
  overrideJsonLd?: Record<string, unknown>;
  /** When set, renders <meta name="robots"> and suppresses canonical/hreflang/JSON-LD. */
  robotsMeta?: string;
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  tags = undefined,
  articleBody = undefined,
  overrideJsonLd,
  htmlLang: htmlLangProp,
  robotsMeta,
} = Astro.props;

const isErrorPage = !!robotsMeta;

const { locale } = Astro.params;
/** Unprefixed routes = default locale (en), per astro.config i18n */
const currentLang = (htmlLangProp ?? locale ?? "en") as string;

const socialImageURL = new URL(ogImage, Astro.url);
const canonicalHref =
  typeof canonicalURL === "string" ? canonicalURL : canonicalURL.href;
const publisherLogoUrl = new URL(
  SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  Astro.url.origin
).href;

const structuredData = overrideJsonLd ?? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: `${title}`,
  description: `${description}`,
  image: `${socialImageURL}`,
  inLanguage: currentLang,
  ...(pubDatetime && { datePublished: pubDatetime.toISOString() }),
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  ...(articleBody &&
    articleBody.length > 0 && {
      articleBody: articleBody.slice(0, 8000),
    }),
  author: [
    {
      "@type": "Person",
      name: `${author}`,
      ...(profile && { url: profile }),
      sameAs: [PUBLIC_PROFILES.linkedIn, PUBLIC_PROFILES.x],
    },
  ],
  publisher: {
    "@type": "Organization",
    name: SITE.title,
    url: SITE.website.replace(/\/+$/, ""),
    logo: {
      "@type": "ImageObject",
      url: publisherLogoUrl,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalHref,
  },
  ...(tags &&
    tags.length > 0 && {
      keywords: tags.join(", "),
    }),
};
---

<!doctype html>
<html
  dir={SITE.dir}
  lang={currentLang}
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {robotsMeta && <meta name="robots" content={robotsMeta} />}
    {!isErrorPage && <link rel="canonical" href={canonicalURL} />}
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect hints (shared, de-duplicated) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Playfair Display (logo) — non-blocking -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" />
    </noscript>

    <!-- Body font — per language, non-blocking -->
    {
      currentLang === "en" && (
        <>
          <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap"
          />
          <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap"
            media="print"
            onload="this.media='all'"
          />
          <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" /></noscript>
        </>
      )
    }
    {
      currentLang === "ja" && (
        <>
          <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap"
          />
          <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap"
            media="print"
            onload="this.media='all'"
          />
          <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" /></noscript>
        </>
      )
    }
    {
      currentLang === "ko" && (
        <>
          <link
            rel="preload"
            as="style"
            crossorigin
            href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
          />
          <link
            rel="stylesheet"
            crossorigin
            href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
            media="print"
            onload="this.media='all'"
          />
          <noscript><link rel="stylesheet" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css" /></noscript>
        </>
      )
    }

    <!-- Apply native typography based on language -->
    <style is:inline>
      html[lang="en"] {
        --font-app: "Inter", sans-serif;
      }
      html[lang="ko"] {
        --font-app: "Pretendard Variable", Pretendard, -apple-system, BlinkMacSystemFont, system-ui, Roboto, "Helvetica Neue", "Segoe UI", "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", sans-serif;
      }
      html[lang="ja"] {
        --font-app: "Noto Sans JP", sans-serif;
      }
    </style>

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    {/* Google JSON-LD Structured data — suppressed on error pages */}
    {!isErrorPage && (
      <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(structuredData)}
      />
    )}

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta name="theme-color" content="" />

    {
      // If PUBLIC_GOOGLE_SITE_VERIFICATION is set in the environment variable,
      // include google-site-verification tag in the heading
      // Learn more: https://support.google.com/webmasters/answer/9008080#meta_tag_verification&zippy=%2Chtml-tag
      PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }

    {
      PUBLIC_ADSENSE_PUBLISHER_ID && (
        <>
          <meta
            name="google-adsense-account"
            content={PUBLIC_ADSENSE_PUBLISHER_ID}
          />
          {/*
            AdSense loader — always injected for Google review bot visibility.
            CookieConsent.astro may call window.__gsfEnableAdsense() on accept;
            we expose a noop so that call is harmless.
          */}
          <script
            async
            src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${PUBLIC_ADSENSE_PUBLISHER_ID}`}
            crossorigin="anonymous"
          />
          <script is:inline>
            // noop — keeps CookieConsent.astro compatible
            window.__gsfEnableAdsense = function () {};
          </script>
        </>
      )
    }

    {/* Google Analytics 4 */}
    {
      PUBLIC_GA4_MEASUREMENT_ID && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${PUBLIC_GA4_MEASUREMENT_ID}`}
          />
          <script
            is:inline
            define:vars={{ gaId: PUBLIC_GA4_MEASUREMENT_ID }}
          >
            window.dataLayer = window.dataLayer || [];
            function gtag() { window.dataLayer.push(arguments); }
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', gaId, { send_page_view: true });
          </script>
        </>
      )
    }

    <ClientRouter />

    <!--
      View transitions replace body content but keep the live <html> element.
      Sync lang from the incoming document so Pagefind / i18n match the URL
      (e.g. /search/ must use lang="en", not a stale "ko" from /ko/...).
    -->
    <script is:inline>
      document.addEventListener("astro:before-swap", function (ev) {
        if (!ev || !("newDocument" in ev) || !ev.newDocument) return;
        var lang = ev.newDocument.documentElement &&
          ev.newDocument.documentElement.getAttribute("lang");
        if (lang) document.documentElement.setAttribute("lang", lang);
      });
    </script>

    <!-- Minimal inline script to prevent FOUC - sets theme immediately -->
    <script is:inline>
      (function () {
        const initialColorScheme = ""; // "light" | "dark"
        const currentTheme = localStorage.getItem("theme");

        function getPreferTheme() {
          if (currentTheme) return currentTheme;
          if (initialColorScheme) return initialColorScheme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = getPreferTheme();

        // Set theme immediately to prevent flash
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        // Export minimal API for external script
        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>
    <script is:inline>
      // CTA click instrumentation: works with or without analytics providers.
      document.addEventListener("click", function (event) {
        var target = event.target;
        if (!(target instanceof Element)) return;
        var anchor = target.closest("a[data-cta]");
        if (!(anchor instanceof HTMLAnchorElement)) return;

        var payload = {
          name: anchor.dataset.cta || "unknown",
          location: anchor.dataset.ctaLocation || "unknown",
          label: anchor.dataset.ctaName || anchor.textContent?.trim() || "",
          href: anchor.href,
          path: window.location.pathname,
        };

        if (typeof window.gtag === "function") {
          window.gtag("event", "cta_click", {
            event_category: "engagement",
            event_label: payload.label || payload.name,
            cta_name: payload.name,
            cta_location: payload.location,
            destination: payload.href,
            page_path: payload.path,
          });
        }

        if (typeof window.plausible === "function") {
          window.plausible("CTA Click", {
            props: {
              cta_name: payload.name,
              cta_location: payload.location,
              destination: payload.href,
            },
          });
        }

        window.dispatchEvent(new CustomEvent("gsf:cta_click", { detail: payload }));
      });
    </script>
  </head>
  <body>
    <slot />



    <!-- Load full theme logic -->
    <script src="../scripts/theme.ts"></script>

    <!-- Vercel Web Analytics -->
    <script>
      import { inject } from "@vercel/analytics";
      inject();
    </script>
  </body>
</html>
